PORT=3005
HOST=0.0.0.0
SESSION_SECRET=change-me-to-a-long-random-secret
COOKIE_SECURE=false
SESSION_STORE=sqlite
# Set to 1, true, loopback, or a trusted proxy subnet only when the app is behind a trusted reverse proxy.
TRUST_PROXY=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASS_HASH=replace-with-bcrypt-hash
DEFAULT_TENANT_ID=default
# Optional. In production, point this to a persistent directory outside the release code path.
WHASAPPC_DATA_DIR=
WHATSAPP_MAX_AUTO_RETRIES=3
KEEP_AWAKE_DURING_CAMPAIGN=true
CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_BATCH_PAUSE_MINUTES=40
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
UPLOAD_MAX_FILE_SIZE_BYTES=52428800
MEDIA_TOTAL_QUOTA_BYTES=524288000
MEDIA_RETENTION_MS=604800000
EXCEL_IMPORT_TIMEOUT_MS=30000
LOG_LEVEL=info
BACKUP_RETENTION_COUNT=30
# Empty value keeps retention disabled. Set for example 180 to purge older audit logs daily.
AUDIT_RETENTION_DAYS=
